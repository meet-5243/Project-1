# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string (from https://cloud.mongodb.com)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/hostelsplit?appName=Cluster0

# JWT secret key — use a long random string in production
JWT_SECRET=your-super-secret-key-here

# Server port (Render sets this automatically, leave as-is)
PORT=5000
